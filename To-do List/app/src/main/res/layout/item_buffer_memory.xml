<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="10dp"
    android:layout_marginTop="10dp"
    android:layout_marginBottom="10dp"
    android:descendantFocusability = "blocksDescendants">

    <TextView
        android:id="@+id/item_name_buffer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toLeftOf="@id/completed_buffer"
        android:layout_alignParentStart="true"
        android:layout_alignParentLeft="true"/>

    <CheckBox
        android:id="@+id/completed_buffer"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_toLeftOf="@id/rmvButton_buffer"
        android:button="@android:drawable/checkbox_on_background" />

    <ImageButton
        android:id="@+id/rmvButton_buffer"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentRight="true"
        android:background="@color/cardview_light_background"
        android:src="@android:drawable/btn_dialog" />
</RelativeLayout>