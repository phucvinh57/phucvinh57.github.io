---
import Container from '@/components/Container.astro';
import Link from '@/components/Link.astro';
import { ABOUT, SITE } from '@/consts';
import SiteLayout from '@/layouts/SiteLayout.astro';
---

<SiteLayout title={ABOUT.TITLE} description={ABOUT.DESCRIPTION}>
  <Container>
    <div class="space-y-10">
      <h1 class="animate font-semibold text-black dark:text-white">
        About
      </h1>

      <section class="space-y-4 leading-7">
        <p class="animate">
          I am Nguyen Phuc Vinh. I use this site as a compact notebook for
          software development, systems, and the ideas I am learning in public.
        </p>
        <p class="animate">
          The goal is simple: write clearly enough that future me can come back
          and still understand the thought.
        </p>
        <p class="animate">
          You can also find me on
          <Link href={SITE.GITHUB} external aria-label={`${SITE.NAME} on GitHub`}>
            GitHub
          </Link>.
        </p>
      </section>
    </div>
  </Container>
</SiteLayout>
