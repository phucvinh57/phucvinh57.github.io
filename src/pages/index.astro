---
import { getCollection } from "astro:content";
import ArrowCard from "@/components/ArrowCard.astro";
import Container from "@/components/Container.astro";
import Link from "@/components/Link.astro";
import { HOME, SITE } from "@/consts";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { getPublishedPosts, sortPosts } from "@/lib/blog";

const posts = sortPosts(getPublishedPosts(await getCollection("blog"))).slice(
  0,
  SITE.NUM_POSTS_ON_HOMEPAGE,
);
---

<SiteLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <h1 class="animate mb-6 text-lg font-semibold text-black dark:text-white">
      Hi, I'm Vinh
    </h1>

    <div class="space-y-16">
      <p class="animate">
        I write about software development, systems and my viewpoints.
      </p>

      <section class="animate space-y-6">
        <div class="flex flex-wrap items-center justify-between gap-y-2">
          <h2 class="font-semibold text-black dark:text-white">Latest posts</h2>
          <Link href="/blog/">See all posts</Link>
        </div>
        <ul class="flex flex-col gap-4">
          {
            posts.map((post) => (
              <li>
                <ArrowCard post={post} />
              </li>
            ))
          }
        </ul>
      </section>
    </div>
  </Container>
</SiteLayout>
