---
import type { BlogPost } from '@/lib/blog';
import { getPostUrl } from '@/lib/blog';

interface Props {
  post: BlogPost;
  href?: string;
}

const { post, href = getPostUrl(post) } = Astro.props;
---

<a
  href={href}
  class="group relative flex flex-nowrap rounded-lg border border-black/15 px-4 py-3 pr-10 text-current transition-colors duration-300 ease-in-out hover:bg-black/5 hover:text-black dark:border-white/20 dark:hover:bg-white/5 dark:hover:text-white"
>
  <div class="flex min-w-0 flex-1 flex-col">
    <div class="truncate font-semibold text-black dark:text-white">
      {post.data.title}
    </div>
    <div class="line-clamp-2 text-sm">
      {post.data.description}
    </div>
  </div>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    aria-hidden="true"
    class="absolute right-2 top-1/2 size-5 -translate-y-1/2 fill-none stroke-current stroke-2"
  >
    <line
      x1="5"
      y1="12"
      x2="19"
      y2="12"
      class="scale-x-0 translate-x-3 transition-transform duration-300 ease-in-out group-hover:scale-x-100 group-hover:translate-x-0"
    />
    <polyline
      points="12 5 19 12 12 19"
      class="-translate-x-1 transition-transform duration-300 ease-in-out group-hover:translate-x-0"
    />
  </svg>
</a>
