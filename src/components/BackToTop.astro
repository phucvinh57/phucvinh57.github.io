<button
  id="back-to-top"
  aria-label="Back to top"
  class="group fixed bottom-6 right-6 z-50 flex size-11 items-center justify-center rounded-full border border-black/15 bg-stone-100/90 text-current shadow-lg backdrop-blur-sm transition-all duration-300 ease-in-out hover:bg-white hover:text-black dark:border-white/20 dark:bg-stone-900/90 dark:hover:bg-stone-800 dark:hover:text-white sm:bottom-8 sm:right-8"
  type="button"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    aria-hidden="true"
    class="size-5 fill-none stroke-current stroke-2 transition-transform duration-300 ease-in-out group-hover:-translate-y-0.5"
  >
    <line
      x1="12"
      y1="19"
      x2="12"
      y2="5"
      class="transition-transform duration-300 ease-in-out group-hover:scale-y-110"
    />
    <polyline
      points="5 12 12 5 19 12"
      class="transition-transform duration-300 ease-in-out group-hover:-translate-y-0.5"
    />
  </svg>
  <span class="sr-only">Back to top</span>
</button>
